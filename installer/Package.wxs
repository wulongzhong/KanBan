<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="KanBan"
           Manufacturer="KanBan"
           Version="$(var.ProductVersion)"
           UpgradeCode="7c4e9a2b-8d1f-4e6a-9b3c-2f5d8e1a0c6b"
           Scope="perUserOrMachine"
           Compressed="yes"
           Codepage="65001">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version is already installed." />

    <MediaTemplate EmbedCab="yes" CompressionLevel="medium" />

    <Feature Id="Main" Title="KanBan" Level="1">
      <ComponentGroupRef Id="PublishedApp" />
      <ComponentRef Id="StartMenuShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <UI>
      <UIRef Id="KanBanUI" />
    </UI>

    <InstallUISequence>
      <Show Dialog="KanBanFinishDlg" OnExit="success" />
      <Show Dialog="override ExitDialog" OnExit="success" Condition="0" />
    </InstallUISequence>

    <AdminUISequence>
      <Show Dialog="KanBanFinishDlg" OnExit="success" />
      <Show Dialog="override ExitDialog" OnExit="success" Condition="0" />
    </AdminUISequence>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="KanBan" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="KanBan" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Component Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="KanBan"
                Description="KanBan"
                Target="[INSTALLFOLDER]KanBan.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU"
                     Key="Software\KanBan"
                     Name="Installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
      <RemoveFolder Id="RemoveAppProgramsFolder"
                    Directory="ApplicationProgramsFolder"
                    On="uninstall" />
    </Component>

    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
      <Shortcut Id="DesktopShortcut"
                Name="KanBan"
                Description="KanBan"
                Target="[INSTALLFOLDER]KanBan.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU"
                     Key="Software\KanBan"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>
  </Package>
</Wix>
