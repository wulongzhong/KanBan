<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KanBan.Views.WorkspacePromptWindow"
        Title="需要设置工作区"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        RequestedThemeVariant="Dark">
    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="使用 KanBan 前请先选择工作区文件夹。"
                   FontSize="15"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>
        <TextBlock Text="看板数据与卡片附件将保存在该目录中。未设置工作区前无法使用应用。"
                   TextWrapping="Wrap"
                   Foreground="#9ca3af"
                   LineHeight="20"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,8,0,0">
            <Button Content="退出"
                    MinWidth="88"
                    Click="Exit_Click"/>
            <Button Content="选择文件夹"
                    Classes="accent"
                    MinWidth="108"
                    Click="Select_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
