<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KanBan.ViewModels"
        xmlns:ctrl="using:KanBan.Views.Controls"
        xmlns:conv="using:KanBan.Views.Converters"
        xmlns:loc="using:KanBan.Markup"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="780"
        x:Class="KanBan.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{loc:Loc Key=App.Title}"
        Width="1280"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        Background="#F5F3EF"
        RequestedThemeVariant="Light"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        WindowDecorations="Full">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:FilePathToBitmapConverter x:Key="FilePathToBitmap"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="WindowDrawnDecorations /template/ Button#PART_FullScreenButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Width" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Image.cardPreview">
            <Setter Property="MaxHeight" Value="180"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="StackPanel.swimlaneRow">
            <Setter Property="Spacing" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="StackPanel.swimlaneRow.collapsed">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style Selector="ItemsControl.laneColumns > ContentPresenter">
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="40,*"
          IsEnabled="{Binding IsWorkspaceReady}">
        <!-- Single full-width row: title left, toolbar right, search + badge centered on the bar (overlapping layers, intrinsic widths). -->
        <Grid Grid.Row="0"
              Classes="titleBarHost"
              Margin="8,0,152,0"
              WindowDecorationProperties.ElementRole="User"
              PointerPressed="TitleBar_PointerPressed">
            <ctrl:InlineRenameHost x:Name="BoardTitleRename"
                                   VerticalAlignment="Center"
                                   Text="{Binding BoardTitle}"
                                   IsEditing="{Binding IsBoardTitleEditing}"
                                   EnableClickToEdit="True"
                                   MinHitWidth="72"
                                   MaxHitWidth="180"
                                   DisplayClasses="boardTitleDisplay"
                                   EditorClasses="ghost boardTitle"
                                   BeginEditRequested="BoardTitleRename_BeginEditRequested"
                                   EditorKeyDown="BoardTitleEdit_KeyDown"
                                   EditorLostFocus="BoardTitleEdit_LostFocus"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Classes="toolbarGhost"
                        Classes.active="{Binding ShowArchive}"
                        Content="{loc:Loc Key=Toolbar.Archive}"
                        Command="{Binding ToggleArchiveCommand}"/>
                <Button Classes="toolbarGhost"
                        Classes.active="{Binding ShowSettings}"
                        Content="{loc:Loc Key=Toolbar.Settings}"
                        Command="{Binding ToggleSettingsCommand}"/>
                <Button Classes="toolbarLink"
                        Content="{loc:Loc Key=Toolbar.Swimlane}"
                        Command="{Binding AddSwimlaneCommand}"
                        ToolTip.Tip="{loc:Loc Key=Toolbar.AddSwimlane.Tooltip}"/>
                <Button Classes="toolbarLink"
                        Content="{loc:Loc Key=Toolbar.CreateList}"
                        Command="{Binding AddLaneCommand}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Border Classes="searchShell">
                    <Grid ColumnDefinitions="Auto,*">
                        <Path Grid.Column="0"
                              Classes="searchIcon"
                              Margin="10,0,2,0"
                              VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Classes="searchInline"
                                 Text="{Binding SearchQuery}"
                                 PlaceholderText="{loc:Loc Key=Toolbar.SearchPlaceholder}"/>
                    </Grid>
                </Border>
                <Border Classes="statBadge" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalCardsText}"/>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="#ECEAE4">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Classes="boardColumnHeaderHost">
                    <ScrollViewer x:Name="ColumnHeaderScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  ScrollChanged="ColumnHeaderScrollViewer_ScrollChanged">
                        <ItemsControl Classes="columnHeaderItems"
                                      ItemsSource="{Binding ColumnLanes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LaneViewModel">
                                    <Grid Width="{Binding ColumnGridWidth}" VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Classes="columnSeparator"
                                                IsVisible="{Binding ShowLeadingSeparator}"/>
                                        <Border Grid.Column="1"
                                                Classes="columnHeader"
                                                Classes.collapsed="{Binding IsCollapsed}"
                                                PointerPressed="LaneHeader_PointerPressed"
                                                PointerMoved="LaneHeader_PointerMoved"
                                                DoubleTapped="LaneHeader_DoubleTapped">
                                        <Grid VerticalAlignment="Center">
                                            <Grid ColumnDefinitions="*,Auto,Auto"
                                                  IsVisible="{Binding IsExpanded}">
                                            <Grid Grid.Column="0"
                                                  ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="6"
                                                  VerticalAlignment="Center">
                                                <Button Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Classes="collapseToggle column"
                                                        Command="{Binding ToggleCollapseCommand}"
                                                        ToolTip.Tip="{Binding CollapseToolTip}">
                                                    <Viewbox Classes="collapseIconHost">
                                                        <Panel Width="16" Height="16">
                                                            <Path Classes="collapseIcon collapseIconLeft"/>
                                                        </Panel>
                                                    </Viewbox>
                                                </Button>
                                                <ctrl:InlineRenameHost Grid.Column="1"
                                                                       FillAvailableSpace="True"
                                                                       VerticalAlignment="Center"
                                                                       MinHitWidth="48"
                                                                       Text="{Binding Title}"
                                                                       DisplayText="{Binding HeaderTitle}"
                                                                       IsEditing="{Binding IsEditing}"
                                                                       DisplayClasses="columnTitleName"
                                                                       EditorClasses="columnTitleEditor"
                                                                       EditorKeyDown="LaneTitleEdit_KeyDown"
                                                                       EditorLostFocus="LaneTitleEdit_LostFocus"/>
                                            </Grid>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding WipText}"
                                                       Classes="columnTitle"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,2,0"/>
                                            <Button Grid.Column="2"
                                                    Classes="cardMenu"
                                                    Content="⋮"
                                                    Padding="4"
                                                    VerticalAlignment="Center">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="{loc:Loc Key=Lane.Collapse}"
                                                                  Command="{Binding ToggleCollapseCommand}"
                                                                  IsVisible="{Binding IsExpanded}"/>
                                                        <MenuItem Header="{loc:Loc Key=Lane.Expand}"
                                                                  Command="{Binding ToggleCollapseCommand}"
                                                                  IsVisible="{Binding IsCollapsed}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Loc Key=Lane.MoveLeft}" Command="{Binding MoveLeftCommand}"/>
                                                        <MenuItem Header="{loc:Loc Key=Lane.MoveRight}" Command="{Binding MoveRightCommand}"/>
                                                        <MenuItem Header="{loc:Loc Key=Lane.SortNow}" Command="{Binding SortCommand}"/>
                                                        <MenuItem Header="{loc:Loc Key=Lane.DeleteList}" Command="{Binding DeleteLaneCommand}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                            </Grid>
                                            <Grid IsVisible="{Binding IsCollapsed}"
                                                  ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="4"
                                                  VerticalAlignment="Center">
                                                <Button Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Classes="collapseToggle column collapsedHeader"
                                                        Command="{Binding ToggleCollapseCommand}"
                                                        ToolTip.Tip="{Binding CollapseToolTip}">
                                                    <Viewbox Classes="collapseIconHost">
                                                        <Panel Width="16" Height="16">
                                                            <Path Classes="collapseIcon collapseIconRight"/>
                                                        </Panel>
                                                    </Viewbox>
                                                </Button>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding HeaderTitle}"
                                                           Classes="columnTitleName ellipsis"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="1" Classes="boardSurface">
                <ScrollViewer x:Name="BoardBodyScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,16"
                              ClipToBounds="True"
                              ScrollChanged="BoardBodyScrollViewer_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding Swimlanes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SwimlaneViewModel">
                                <StackPanel Classes="swimlaneRow"
                                            Classes.collapsed="{Binding IsCollapsed}">
                                    <Border Classes="swimlaneBar"
                                            DoubleTapped="SwimlaneLabel_DoubleTapped">
                                        <Grid ColumnDefinitions="*,Auto"
                                              VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Button Classes="collapseToggle swimlane"
                                                        Command="{Binding ToggleCollapseCommand}"
                                                        ToolTip.Tip="{Binding CollapseToolTip}">
                                                    <Viewbox Classes="collapseIconHost">
                                                        <Panel Width="16" Height="16">
                                                            <Path Classes="collapseIcon collapseIconUp"
                                                                  IsVisible="{Binding IsExpanded}"/>
                                                            <Path Classes="collapseIcon collapseIconDown"
                                                                  IsVisible="{Binding IsCollapsed}"/>
                                                        </Panel>
                                                    </Viewbox>
                                                </Button>
                                                <ctrl:InlineRenameHost Text="{Binding Title}"
                                                                       IsEditing="{Binding IsEditing}"
                                                                       MinHitWidth="96"
                                                                       MaxHitWidth="320"
                                                                       DisplayClasses="swimlaneTitle"
                                                                       EditorClasses="swimlaneTitle"
                                                                       EditorKeyDown="SwimlaneTitleEdit_KeyDown"
                                                                       EditorLostFocus="SwimlaneTitleEdit_LostFocus"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Classes="cardMenu"
                                                    Content="⋮"
                                                    Padding="3,0,0,0"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="{loc:Loc Key=Swimlane.Collapse}"
                                                                  Command="{Binding ToggleCollapseCommand}"
                                                                  IsVisible="{Binding IsExpanded}"/>
                                                        <MenuItem Header="{loc:Loc Key=Swimlane.Expand}"
                                                                  Command="{Binding ToggleCollapseCommand}"
                                                                  IsVisible="{Binding IsCollapsed}"/>
                                                        <Separator/>
                                                        <MenuItem Header="{loc:Loc Key=Swimlane.Rename}" Command="{Binding BeginEditCommand}"/>
                                                        <MenuItem Header="{loc:Loc Key=Swimlane.MoveUp}" Command="{Binding MoveUpCommand}"/>
                                                        <MenuItem Header="{loc:Loc Key=Swimlane.MoveDown}" Command="{Binding MoveDownCommand}"/>
                                                        <MenuItem Header="{loc:Loc Key=Swimlane.Delete}" Command="{Binding DeleteSwimlaneCommand}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <ItemsControl Classes="laneColumns"
                                                  ItemsSource="{Binding Lanes}"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LaneViewModel">
                                <Grid Width="{Binding ColumnGridWidth}" VerticalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Classes="columnSeparator"
                                            IsVisible="{Binding ShowLeadingSeparator}"/>
                                <Grid Grid.Column="1"
                                      Width="{Binding ColumnWidth}"
                                      RowDefinitions="Auto,*"
                                      VerticalAlignment="Stretch"
                                      IsVisible="{Binding IsExpanded}">
                                    <StackPanel Grid.Row="0">
                                    <Border Classes="laneCell">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Border Grid.Row="0" Padding="4,4,4,8" IsVisible="False">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="{Binding WipText}"
                                                               Classes="muted"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Classes="cardMenu" Content="⋮" Padding="4">
                                                        <Button.Flyout>
                                                            <MenuFlyout>
                                                                <MenuItem Header="{loc:Loc Key=Lane.AddCard}" Command="{Binding AddCardCommand}"/>
                                                                <MenuItem Header="{loc:Loc Key=Lane.SortNow}" Command="{Binding SortCommand}"/>
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <ItemsControl Grid.Row="1"
                                                          ItemsSource="{Binding FilteredCards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CardViewModel">
                                                    <Border Classes="card"
                                                            DragDrop.AllowDrop="True"
                                                            Focusable="True"
                                                            PointerPressed="Card_PointerPressed"
                                                            PointerMoved="Card_PointerMoved"
                                                            DoubleTapped="Card_DoubleTapped"
                                                            DragDrop.DragOver="Card_DragOver"
                                                            DragDrop.Drop="Card_Drop"
                                                            KeyDown="Card_KeyDown">
                                                        <Grid>
                                                            <StackPanel Spacing="6" IsVisible="{Binding IsDisplayMode}">
                                                                <ItemsControl ItemsSource="{Binding Tags}"
                                                                              IsVisible="{Binding HasTags}"
                                                                              Margin="8,8,8,0">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardTagViewModel">
                                                                            <Border Classes="tagPill"
                                                                                    Background="{Binding Background}">
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           Foreground="{Binding Foreground}"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="{Binding SummaryText}"
                                                                           Classes="cardBody"
                                                                           Margin="8,8,28,0"
                                                                           IsVisible="{Binding HasDescription}"/>

                                                                <ItemsControl ItemsSource="{Binding PreviewImages}"
                                                                              IsVisible="{Binding HasPreviewImages}"
                                                                              Margin="8,4,10,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                            <Image Classes="cardPreview"
                                                                                   Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                                   DoubleTapped="CardImage_DoubleTapped"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <WrapPanel Margin="8,0,8,7">
                                                                    <Button Classes="tagButton dateBadge"
                                                                            Content="{Binding DateDisplayText}"
                                                                            IsVisible="{Binding HasDueDate}"
                                                                            Click="CardDateBadge_Click"/>
                                                                    <Button Classes="tagButton timeBadge"
                                                                            Content="{Binding TimeDisplayText}"
                                                                            IsVisible="{Binding HasDueTime}"
                                                                            Click="CardTimeBadge_Click"/>
                                                                    <Border Classes="tag" IsVisible="{Binding ShowRelativeDueBadge}">
                                                                        <TextBlock Text="{Binding DueBadge}" FontSize="11"/>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </StackPanel>

                                                            <Button Classes="cardMenu overlay"
                                                                    Content="⋮"
                                                                    IsVisible="{Binding IsDisplayMode}"
                                                                    Tag="{Binding}"
                                                                    PointerPressed="CardMenu_PointerPressed">
                                                                <Button.Flyout>
                                                                    <MenuFlyout>
                                                                        <MenuItem Header="{loc:Loc Key=Card.Edit}" Command="{Binding BeginEditCommand}"/>
                                                                        <MenuItem Header="{loc:Loc Key=Card.MoveUp}" Command="{Binding MoveUpCommand}"/>
                                                                        <MenuItem Header="{loc:Loc Key=Card.MoveDown}" Command="{Binding MoveDownCommand}"/>
                                                                        <MenuItem Header="{loc:Loc Key=Card.Archive}" Command="{Binding ArchiveCommand}"/>
                                                                        <MenuItem Header="{loc:Loc Key=Card.Delete}" Command="{Binding DeleteCommand}"/>
                                                                        <Separator/>
                                                                        <MenuItem Header="{Binding DateMenuHeader}"
                                                                                  Click="CardMenu_Date_Click"/>
                                                                        <MenuItem Header="{loc:Loc Key=Card.RemoveDate}"
                                                                                  Command="{Binding ClearDueDateCommand}"
                                                                                  IsVisible="{Binding ShowRemoveDateMenu}"/>
                                                                        <MenuItem Header="{Binding TimeMenuHeader}"
                                                                                  Click="CardMenu_Time_Click"
                                                                                  IsVisible="{Binding ShowTimeMenuSection}"/>
                                                                        <MenuItem Header="{loc:Loc Key=Card.RemoveTime}"
                                                                                  Command="{Binding ClearDueTimeCommand}"
                                                                                  IsVisible="{Binding ShowRemoveTimeMenu}"/>
                                                                    </MenuFlyout>
                                                                </Button.Flyout>
                                                            </Button>

                                                            <StackPanel Spacing="6" Margin="8" IsVisible="{Binding IsEditing}">
                                                                <TextBox Classes="cardDetails"
                                                                         Text="{Binding Description}"
                                                                         PlaceholderText="{loc:Loc Key=Card.DetailsPlaceholder}"
                                                                         Loaded="CardDetailsEditor_Loaded"/>
                                                                <TextBlock Text="{loc:Loc Key=Card.DropImagesOnCard}"
                                                                           Classes="faint"
                                                                           FontSize="11"/>
                                                                <ItemsControl ItemsSource="{Binding PreviewImages}"
                                                                              IsVisible="{Binding HasPreviewImages}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                            <Border Margin="0,0,0,6"
                                                                                    CornerRadius="4"
                                                                                    ClipToBounds="True"
                                                                                    Classes="cardImagePlaceholder">
                                                                                <Grid>
                                                                                    <Image Classes="cardPreview"
                                                                                           Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                                           DoubleTapped="CardImage_DoubleTapped"/>
                                                                                    <Button Classes="cardImageRemove"
                                                                                            ToolTip.Tip="{loc:Loc Key=Card.RemoveImage.Tooltip}"
                                                                                            Command="{Binding RemoveCommand}">
                                                                                        <Path Classes="cardImageRemoveIcon"/>
                                                                                    </Button>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <Button Classes="accent" Content="{loc:Loc Key=Card.Done}" Command="{Binding EndEditCommand}"/>
                                                                    <Button Content="{loc:Loc Key=Card.ArchiveButton}" Command="{Binding ArchiveCommand}"/>
                                                                    <Button Content="{loc:Loc Key=Card.DeleteButton}" Command="{Binding DeleteCommand}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </Grid>
                                    </Border>
                                    <Border Classes="laneCellFooter">
                                        <StackPanel Spacing="0">
                                            <Border Padding="0,0,0,8"
                                                    IsVisible="{Binding IsAddingCard}"
                                                    DragDrop.DragOver="NewCardComposer_DragOver"
                                                    DragDrop.Drop="NewCardComposer_Drop"
                                                    KeyDown="NewCardComposer_KeyDown">
                                                <StackPanel Spacing="6">
                                                    <TextBox Classes="cardDetails"
                                                             Text="{Binding NewCardDetails}"
                                                             PlaceholderText="{loc:Loc Key=Card.DetailsPlaceholder}"
                                                             Loaded="NewCardComposerEditor_Loaded"/>
                                                    <TextBlock Text="{loc:Loc Key=Card.DropImagesHere}"
                                                               Classes="faint"
                                                               FontSize="11"/>
                                                    <ItemsControl ItemsSource="{Binding NewCardPreviewImages}"
                                                                  IsVisible="{Binding HasNewCardPreviewImages}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                <Border Margin="0,0,0,6"
                                                                        CornerRadius="4"
                                                                        ClipToBounds="True"
                                                                        Classes="cardImagePlaceholder">
                                                                    <Grid>
                                                                        <Image Classes="cardPreview"
                                                                               Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                               DoubleTapped="CardImage_DoubleTapped"/>
                                                                        <Button Classes="cardImageRemove"
                                                                                ToolTip.Tip="{loc:Loc Key=Card.RemoveImage.Tooltip}"
                                                                                Command="{Binding RemoveCommand}">
                                                                            <Path Classes="cardImageRemoveIcon"/>
                                                                        </Button>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Button Classes="accent" Content="{loc:Loc Key=Card.Add}" Command="{Binding CommitAddCardCommand}"/>
                                                        <Button Content="{loc:Loc Key=Card.Cancel}" Command="{Binding CancelAddCardCommand}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Button Classes="laneAddCard"
                                                    Content="{loc:Loc Key=Card.AddCardButton}"
                                                    Command="{Binding AddCardCommand}"
                                                    IsVisible="{Binding IsAddCardButtonVisible}"/>
                                        </StackPanel>
                                    </Border>
                                    </StackPanel>
                                    <Border Grid.Row="1"
                                            Classes="laneDropZone"
                                            Background="Transparent"/>
                                </Grid>
                                    <Border Grid.Column="1"
                                            Width="{Binding ColumnWidth}"
                                            Classes="columnCollapsedStrip"
                                            IsVisible="{Binding IsCollapsed}"/>
                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Border>
            </Grid>

            <Border Classes="drawer"
                    Width="360"
                    Padding="14"
                    Margin="0,12,12,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    IsVisible="{Binding ShowArchive}">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Key=Archive.Title}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ArchiveCountText}" Classes="muted"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="×" Command="{Binding ToggleArchiveCommand}"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
                        <ItemsControl ItemsSource="{Binding ArchiveCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CardViewModel">
                                    <Border Classes="card" Padding="9">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Description}" Classes="cardBody" IsVisible="{Binding HasDescription}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button Content="{loc:Loc Key=Archive.Restore}" Command="{Binding RestoreCommand}"/>
                                                <Button Content="{loc:Loc Key=Card.DeleteButton}" Command="{Binding DeleteCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Classes="drawer"
                    Width="360"
                    Padding="14"
                    Margin="0,12,12,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    IsVisible="{Binding ShowSettings}">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{loc:Loc Key=Settings.Title}" FontSize="18" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="×" Command="{Binding ToggleSettingsCommand}"/>
                    </Grid>
                    <TextBlock Text="{loc:Loc Key=Settings.Language}" Classes="muted"/>
                    <ComboBox x:Name="LanguageComboBox"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedIndex="{Binding SelectedLanguageIndex, Mode=OneWay}"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:LanguageOption">
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <CheckBox Content="{loc:Loc Key=Settings.ShowRelativeDates}" IsChecked="{Binding ShowRelativeDates}"/>
                    <CheckBox Content="{loc:Loc Key=Settings.PrependNewCards}" IsChecked="{Binding PrependNewCards}"/>
                    <TextBlock Text="{loc:Loc Key=Settings.MaxArchiveSize}" Classes="muted"/>
                    <TextBox Text="{Binding MaxArchiveSizeText}"/>
                    <TextBlock Text="{loc:Loc Key=Settings.DateFormat}" Classes="muted"/>
                    <TextBox Text="{Binding DateFormat}"/>
                    <TextBlock Text="{loc:Loc Key=Settings.WorkspaceFolder}" Classes="muted"/>
                    <TextBlock Text="{Binding WorkspaceFolderDisplay}"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                    <TextBlock Text="{loc:Loc Key=Settings.BoardFile}" Classes="muted"/>
                    <TextBlock Text="{Binding BoardFilePath}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Classes="faint"/>
                    <Button Content="{loc:Loc Key=Settings.ChangeWorkspace}"
                            Command="{Binding SelectWorkspaceFolderCommand}"/>
                    <Button Content="{loc:Loc Key=Settings.ResetSampleBoard}" Command="{Binding NewBoardCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="muted" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Popup x:Name="DatePickerPopup"
               IsLightDismissEnabled="True"
               Placement="BottomEdgeAlignedLeft"
               OverlayDismissEventPassThrough="False"
               Closed="DatePickerPopup_Closed">
            <ThemeVariantScope RequestedThemeVariant="Light">
                <Border Classes="pickerPopup">
                    <Calendar x:Name="DatePickerCalendar"
                              SelectionMode="SingleDate"
                              SelectedDatesChanged="DatePickerCalendar_SelectedDatesChanged"/>
                </Border>
            </ThemeVariantScope>
        </Popup>

        <Popup x:Name="TimePickerPopup"
               IsLightDismissEnabled="True"
               Placement="BottomEdgeAlignedLeft"
               OverlayDismissEventPassThrough="False"
               Closed="TimePickerPopup_Closed">
            <ThemeVariantScope RequestedThemeVariant="Light">
                <Border Classes="pickerPopup" MinWidth="240">
                    <StackPanel Spacing="10">
                        <TimePicker x:Name="BoardTimePicker"
                                    ClockIdentifier="24HourClock"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Button Grid.Column="1"
                                    Content="{loc:Loc Key=Common.Cancel}"
                                    Click="TimePickerCancel_Click"/>
                            <Button Grid.Column="2"
                                    Classes="accent"
                                    Content="{loc:Loc Key=Common.Confirm}"
                                    Click="TimePickerConfirm_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </ThemeVariantScope>
        </Popup>

        <Canvas Grid.RowSpan="2" IsHitTestVisible="False">
            <Border x:Name="DragPreview"
                    Classes="dragPreview"
                    IsVisible="False"
                    Width="244"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Opacity="0.92">
                <TextBlock x:Name="DragPreviewText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           FontWeight="SemiBold"/>
            </Border>
        </Canvas>

        <Border x:Name="ImageLightbox"
                Grid.RowSpan="2"
                Classes="imageLightbox"
                IsVisible="False"
                Focusable="True"
                KeyDown="ImageLightbox_KeyDown">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock x:Name="ImageLightboxTitle"
                           Grid.Row="0"
                           Classes="imageLightboxTitle"
                           Margin="16,12,16,8"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"/>
                <Grid x:Name="ImageLightboxContentArea"
                      Grid.Row="1"
                      Margin="16,0,16,8"
                      ClipToBounds="True"
                      PointerWheelChanged="ImageLightbox_ContentArea_WheelChanged">
                    <Panel x:Name="ImageLightboxBackdrop"
                           Background="Transparent"
                           PointerPressed="ImageLightbox_Backdrop_PointerPressed"/>
                    <Border x:Name="ImageLightboxImageHost"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            PointerPressed="ImageLightbox_Host_PointerPressed"
                            PointerMoved="ImageLightbox_Host_PointerMoved"
                            PointerReleased="ImageLightbox_Host_PointerReleased"
                            PointerCaptureLost="ImageLightbox_Host_CaptureLost">
                        <Image x:Name="ImageLightboxImage"
                               Stretch="None"
                               DoubleTapped="ImageLightbox_Image_DoubleTapped"/>
                    </Border>
                </Grid>
                <Button Grid.Row="2"
                        Classes="imageLightboxClose"
                        Content="{loc:Loc Key=Common.Close}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,20"
                        Click="ImageLightbox_Close_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
