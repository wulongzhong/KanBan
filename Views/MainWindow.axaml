<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KanBan.ViewModels"
        xmlns:conv="using:KanBan.Views.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="780"
        x:Class="KanBan.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="KanBan"
        Width="1280"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        Background="#FFFFFF"
        RequestedThemeVariant="Light">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:FilePathToBitmapConverter x:Key="FilePathToBitmap"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Image.cardPreview">
            <Setter Property="MaxHeight" Value="180"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="StackPanel.swimlaneRow">
            <Setter Property="Spacing" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*"
          IsEnabled="{Binding IsWorkspaceReady}">
        <Border Grid.Row="0" Classes="toolbar" Padding="16,8,16,8">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                <TextBox Grid.Column="0"
                         Classes="ghost boardTitle"
                         Text="{Binding BoardTitle}"
                         VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Classes="searchShell">
                        <Grid ColumnDefinitions="Auto,*">
                            <Path Grid.Column="0"
                                  Classes="searchIcon"
                                  Margin="10,0,2,0"
                                  VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Classes="searchInline"
                                     Text="{Binding SearchQuery}"
                                     PlaceholderText="Search cards"/>
                        </Grid>
                    </Border>
                    <Border Classes="statBadge" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalCards, StringFormat='{}{0} cards'}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Center">
                    <Button Classes="toolbarGhost"
                            Classes.active="{Binding ShowArchive}"
                            Content="Archive"
                            Command="{Binding ToggleArchiveCommand}"/>
                    <Button Classes="toolbarGhost"
                            Classes.active="{Binding ShowSettings}"
                            Content="Settings"
                            Command="{Binding ToggleSettingsCommand}"/>
                    <Button Classes="toolbarLink"
                            Content="Swimlane"
                            Command="{Binding AddSwimlaneCommand}"
                            ToolTip.Tip="Add swimlane"/>
                    <Button Classes="createList"
                            Content="Create list"
                            Command="{Binding AddLaneCommand}"
                            Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Classes="boardColumnHeaderHost">
                    <ScrollViewer x:Name="ColumnHeaderScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  ScrollChanged="ColumnHeaderScrollViewer_ScrollChanged">
                        <ItemsControl ItemsSource="{Binding ColumnLanes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LaneViewModel">
                                    <Border Classes="columnHeader"
                                            Width="272"
                                            Margin="0,0,12,0"
                                            PointerPressed="LaneHeader_PointerPressed"
                                            PointerMoved="LaneHeader_PointerMoved"
                                            DoubleTapped="LaneHeader_DoubleTapped">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                            <Grid Grid.Column="0">
                                                <TextBlock Text="{Binding HeaderTitle}"
                                                           Classes="columnTitle"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding IsDisplayMode}"/>
                                                <TextBox Text="{Binding Title}"
                                                         FontWeight="Bold"
                                                         FontSize="11"
                                                         KeyDown="LaneEdit_KeyDown"
                                                         LostFocus="LaneEdit_LostFocus"
                                                         IsVisible="{Binding IsEditing}"/>
                                            </Grid>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding WipText}"
                                                       Classes="columnTitle"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" Classes="cardMenu" Content="⋮" Padding="4">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Move left" Command="{Binding MoveLeftCommand}"/>
                                                        <MenuItem Header="Move right" Command="{Binding MoveRightCommand}"/>
                                                        <MenuItem Header="Sort now" Command="{Binding SortCommand}"/>
                                                        <MenuItem Header="Delete list" Command="{Binding DeleteLaneCommand}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="1" Classes="boardSurface">
                <ScrollViewer x:Name="BoardBodyScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,16"
                              ClipToBounds="True"
                              ScrollChanged="BoardBodyScrollViewer_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding Swimlanes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SwimlaneViewModel">
                                <StackPanel Classes="swimlaneRow">
                                    <Border Classes="swimlaneBar"
                                            DoubleTapped="SwimlaneLabel_DoubleTapped">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       Classes="swimlaneTitle"
                                                       IsVisible="{Binding IsDisplayMode}"/>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Title}"
                                                     Classes="swimlaneTitle"
                                                     KeyDown="SwimlaneEdit_KeyDown"
                                                     LostFocus="SwimlaneEdit_LostFocus"
                                                     IsVisible="{Binding IsEditing}"/>
                                            <Button Grid.Column="1"
                                                    Classes="cardMenu"
                                                    Content="⋮"
                                                    Padding="3,0,0,0"
                                                    Margin="8,0,0,0">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Rename swimlane" Command="{Binding BeginEditCommand}"/>
                                                        <MenuItem Header="Move up" Command="{Binding MoveUpCommand}"/>
                                                        <MenuItem Header="Move down" Command="{Binding MoveDownCommand}"/>
                                                        <MenuItem Header="Delete swimlane" Command="{Binding DeleteSwimlaneCommand}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Lanes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LaneViewModel">
                                <StackPanel Width="272"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Top">
                                    <Border Classes="laneCell">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Border Grid.Row="0" Padding="4,4,4,8" IsVisible="False">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="{Binding WipText}"
                                                               Classes="muted"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Classes="cardMenu" Content="⋮" Padding="4">
                                                        <Button.Flyout>
                                                            <MenuFlyout>
                                                                <MenuItem Header="Add a card" Command="{Binding AddCardCommand}"/>
                                                                <MenuItem Header="Sort now" Command="{Binding SortCommand}"/>
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <ItemsControl Grid.Row="1"
                                                          ItemsSource="{Binding FilteredCards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CardViewModel">
                                                    <Border Classes="card"
                                                            DragDrop.AllowDrop="True"
                                                            Focusable="True"
                                                            PointerPressed="Card_PointerPressed"
                                                            PointerMoved="Card_PointerMoved"
                                                            DoubleTapped="Card_DoubleTapped"
                                                            DragDrop.DragOver="Card_DragOver"
                                                            DragDrop.Drop="Card_Drop"
                                                            KeyDown="Card_KeyDown">
                                                        <Grid>
                                                            <StackPanel Spacing="6" IsVisible="{Binding IsDisplayMode}">
                                                                <ItemsControl ItemsSource="{Binding Tags}"
                                                                              IsVisible="{Binding HasTags}"
                                                                              Margin="8,8,8,0">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <WrapPanel/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardTagViewModel">
                                                                            <Border Classes="tagPill"
                                                                                    Background="{Binding Background}">
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           Foreground="{Binding Foreground}"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <Grid Margin="8,0,8,0">
                                                                    <TextBlock Text="{Binding SummaryText}"
                                                                               Classes="cardBody"
                                                                               Margin="0,0,26,0"
                                                                               IsVisible="{Binding HasDescription}"/>
                                                                    <Button Classes="cardMenu"
                                                                            Content="⋮"
                                                                            Padding="3"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top"
                                                                            Tag="{Binding}"
                                                                            PointerPressed="CardMenu_PointerPressed">
                                                                        <Button.Flyout>
                                                                            <MenuFlyout>
                                                                                <MenuItem Header="编辑卡片" Command="{Binding BeginEditCommand}"/>
                                                                                <MenuItem Header="Move up" Command="{Binding MoveUpCommand}"/>
                                                                                <MenuItem Header="Move down" Command="{Binding MoveDownCommand}"/>
                                                                                <MenuItem Header="归档卡片" Command="{Binding ArchiveCommand}"/>
                                                                                <MenuItem Header="删除卡片" Command="{Binding DeleteCommand}"/>
                                                                                <Separator/>
                                                                                <MenuItem Header="{Binding DateMenuHeader}"
                                                                                          Click="CardMenu_Date_Click"/>
                                                                                <MenuItem Header="移除日期"
                                                                                          Command="{Binding ClearDueDateCommand}"
                                                                                          IsVisible="{Binding ShowRemoveDateMenu}"/>
                                                                                <MenuItem Header="{Binding TimeMenuHeader}"
                                                                                          Click="CardMenu_Time_Click"
                                                                                          IsVisible="{Binding ShowTimeMenuSection}"/>
                                                                                <MenuItem Header="移除时间"
                                                                                          Command="{Binding ClearDueTimeCommand}"
                                                                                          IsVisible="{Binding ShowRemoveTimeMenu}"/>
                                                                            </MenuFlyout>
                                                                        </Button.Flyout>
                                                                    </Button>
                                                                </Grid>

                                                                <ItemsControl ItemsSource="{Binding PreviewImages}"
                                                                              IsVisible="{Binding HasPreviewImages}"
                                                                              Margin="8,4,10,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                            <Image Classes="cardPreview"
                                                                                   Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                                   DoubleTapped="CardImage_DoubleTapped"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <WrapPanel Margin="8,0,8,7">
                                                                    <Button Classes="tagButton dateBadge"
                                                                            Content="{Binding DateDisplayText}"
                                                                            IsVisible="{Binding HasDueDate}"
                                                                            Click="CardDateBadge_Click"/>
                                                                    <Button Classes="tagButton timeBadge"
                                                                            Content="{Binding TimeDisplayText}"
                                                                            IsVisible="{Binding HasDueTime}"
                                                                            Click="CardTimeBadge_Click"/>
                                                                    <Border Classes="tag" IsVisible="{Binding ShowRelativeDueBadge}">
                                                                        <TextBlock Text="{Binding DueBadge}" FontSize="11"/>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </StackPanel>

                                                            <StackPanel Spacing="6" Margin="8" IsVisible="{Binding IsEditing}">
                                                                <ItemsControl ItemsSource="{Binding PreviewImages}"
                                                                              IsVisible="{Binding HasPreviewImages}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                            <Border Margin="0,0,0,6"
                                                                                    CornerRadius="4"
                                                                                    ClipToBounds="True"
                                                                                    Background="#EBECF0">
                                                                                <Grid>
                                                                                    <Image Classes="cardPreview"
                                                                                           Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                                           DoubleTapped="CardImage_DoubleTapped"/>
                                                                                    <Button Classes="cardImageRemove"
                                                                                            ToolTip.Tip="移除图片"
                                                                                            Command="{Binding RemoveCommand}">
                                                                                        <Path Classes="cardImageRemoveIcon"/>
                                                                                    </Button>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="拖放图片到卡片，或 Ctrl+V 粘贴"
                                                                           Classes="faint"
                                                                           FontSize="11"/>
                                                                <TextBox Classes="cardDetails"
                                                                         Text="{Binding Description}"
                                                                         PlaceholderText="详情..."
                                                                         KeyDown="CardEdit_KeyDown"/>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <Button Classes="accent" Content="Done" Command="{Binding EndEditCommand}"/>
                                                                    <Button Content="Archive" Command="{Binding ArchiveCommand}"/>
                                                                    <Button Content="Delete" Command="{Binding DeleteCommand}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </Grid>
                                    </Border>
                                    <Border Classes="laneCellFooter">
                                        <StackPanel Spacing="0">
                                            <Border Padding="0,0,0,8" IsVisible="{Binding IsAddingCard}">
                                                <StackPanel Spacing="6">
                                                    <TextBox Classes="cardDetails"
                                                             Text="{Binding NewCardDetails}"
                                                             PlaceholderText="详情..."/>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Button Classes="accent" Content="添加" Command="{Binding CommitAddCardCommand}"/>
                                                        <Button Content="取消" Command="{Binding CancelAddCardCommand}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Button Classes="laneAddCard"
                                                    Content="+ 添加卡片"
                                                    Command="{Binding AddCardCommand}"
                                                    IsVisible="{Binding IsAddCardButtonVisible}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Border>
            </Grid>

            <Border Classes="drawer"
                    Width="360"
                    Padding="14"
                    Margin="0,12,12,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    IsVisible="{Binding ShowArchive}">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="Archive" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ArchiveCount, StringFormat='{}{0} archived cards'}" Classes="muted"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="×" Command="{Binding ToggleArchiveCommand}"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
                        <ItemsControl ItemsSource="{Binding ArchiveCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CardViewModel">
                                    <Border Classes="card" Padding="9">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Description}" Classes="cardBody" IsVisible="{Binding HasDescription}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button Content="Restore" Command="{Binding RestoreCommand}"/>
                                                <Button Content="Delete" Command="{Binding DeleteCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Classes="drawer"
                    Width="360"
                    Padding="14"
                    Margin="0,12,12,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    IsVisible="{Binding ShowSettings}">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Board settings" FontSize="18" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="×" Command="{Binding ToggleSettingsCommand}"/>
                    </Grid>
                    <CheckBox Content="Show relative dates" IsChecked="{Binding ShowRelativeDates}"/>
                    <CheckBox Content="Prepend new cards" IsChecked="{Binding PrependNewCards}"/>
                    <TextBlock Text="Maximum archive size" Classes="muted"/>
                    <TextBox Text="{Binding MaxArchiveSizeText}"/>
                    <TextBlock Text="Date format" Classes="muted"/>
                    <TextBox Text="{Binding DateFormat}"/>
                    <TextBlock Text="工作区文件夹" Classes="muted"/>
                    <TextBlock Text="{Binding WorkspaceFolderDisplay}"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                    <TextBlock Text="看板文件" Classes="muted"/>
                    <TextBlock Text="{Binding BoardFilePath}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Classes="faint"/>
                    <Button Content="更改工作区文件夹"
                            Command="{Binding SelectWorkspaceFolderCommand}"/>
                    <Button Content="Reset sample board" Command="{Binding NewBoardCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="muted" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Popup x:Name="DatePickerPopup"
               IsLightDismissEnabled="True"
               Placement="BottomEdgeAlignedLeft"
               OverlayDismissEventPassThrough="False"
               Closed="DatePickerPopup_Closed">
            <ThemeVariantScope RequestedThemeVariant="Light">
                <Border Classes="pickerPopup">
                    <Calendar x:Name="DatePickerCalendar"
                              SelectionMode="SingleDate"
                              SelectedDatesChanged="DatePickerCalendar_SelectedDatesChanged"/>
                </Border>
            </ThemeVariantScope>
        </Popup>

        <Popup x:Name="TimePickerPopup"
               IsLightDismissEnabled="True"
               Placement="BottomEdgeAlignedLeft"
               OverlayDismissEventPassThrough="False"
               Closed="TimePickerPopup_Closed">
            <ThemeVariantScope RequestedThemeVariant="Light">
                <Border Classes="pickerPopup" MinWidth="240">
                    <StackPanel Spacing="10">
                        <TimePicker x:Name="BoardTimePicker"
                                    ClockIdentifier="24HourClock"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Button Grid.Column="1"
                                    Content="取消"
                                    Click="TimePickerCancel_Click"/>
                            <Button Grid.Column="2"
                                    Classes="accent"
                                    Content="确认"
                                    Click="TimePickerConfirm_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </ThemeVariantScope>
        </Popup>

        <Canvas Grid.RowSpan="2" IsHitTestVisible="False">
            <Border x:Name="DragPreview"
                    IsVisible="False"
                    Width="244"
                    Background="#FFFFFF"
                    BorderBrush="#4C9AFF"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10"
                    Opacity="0.92">
                <TextBlock x:Name="DragPreviewText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           FontWeight="SemiBold"/>
            </Border>
        </Canvas>

        <Border x:Name="ImageLightbox"
                Grid.RowSpan="2"
                Classes="imageLightbox"
                IsVisible="False"
                Focusable="True"
                KeyDown="ImageLightbox_KeyDown"
                PointerPressed="ImageLightbox_Background_PointerPressed">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16,12,16,8">
                    <TextBlock x:Name="ImageLightboxTitle"
                               Classes="muted"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1"
                            Content="×"
                            Padding="10,4"
                            Click="ImageLightbox_Close_Click"/>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              Margin="16,0,16,16"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PointerPressed="ImageLightbox_Scroll_PointerPressed">
                    <Image x:Name="ImageLightboxImage"
                           Stretch="None"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           DoubleTapped="ImageLightbox_Image_DoubleTapped"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
