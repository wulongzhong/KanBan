<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KanBan.ViewModels"
        xmlns:conv="using:KanBan.Views.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="780"
        x:Class="KanBan.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="KanBan"
        Width="1280"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        Background="#1e1e1e"
        RequestedThemeVariant="Dark">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:FilePathToBitmapConverter x:Key="FilePathToBitmap"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Image.cardPreview">
            <Setter Property="MaxHeight" Value="180"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Border.imageLightbox">
            <Setter Property="Background" Value="#D9000000"/>
        </Style>
        <Style Selector="Border.toolbar">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="BorderBrush" Value="#343434"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="Border.searchbar">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="BorderBrush" Value="#343434"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="Border.lane">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.laneHeader">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,8,12,8"/>
        </Style>
        <Style Selector="Border.laneBody">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
        </Style>
        <Style Selector="Border.laneFooter">
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.boardColumnHeaderHost">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="BorderBrush" Value="#343434"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,12,16,10"/>
        </Style>
        <Style Selector="Border.columnHeader">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
            <Setter Property="Padding" Value="10,10,12,10"/>
        </Style>
        <Style Selector="StackPanel.swimlaneRow">
            <Setter Property="Spacing" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style Selector="Border.swimlaneBar">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style Selector="Border.laneCell">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="0,1,1,0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Width" Value="272"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style Selector="Border.laneCellFooter">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
            <Setter Property="CornerRadius" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="272"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style Selector="TextBlock.swimlaneTitle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.laneAddCard">
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style Selector="TextBox.cardDetails">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MinHeight" Value="96"/>
            <Setter Property="MaxHeight" Value="280"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="7,6"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="4,4,4,6"/>
        </Style>
        <Style Selector="Border.card:pointerover">
            <Setter Property="BorderBrush" Value="#565656"/>
        </Style>
        <Style Selector="Border.drawer">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Border.tag">
            <Setter Property="Background" Value="#2c3b58"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
        </Style>
        <Style Selector="Button.tagButton">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Border.pickerPopup">
            <Setter Property="Background" Value="#2b2b2b"/>
            <Setter Property="BorderBrush" Value="#4a4a4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar">
            <Setter Property="Background" Value="#2b2b2b"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar /template/ CalendarDayButton">
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar /template/ CalendarDayButton:pointerover">
            <Setter Property="Background" Value="#3a3a3a"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar /template/ CalendarDayButton:selected">
            <Setter Property="Background" Value="#4f6df5"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar /template/ CalendarDayButton:inactive">
            <Setter Property="Foreground" Value="#6b6b6b"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar /template/ CalendarItem /template/ Button">
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Border.pickerPopup Calendar /template/ CalendarItem /template/ Button:pointerover">
            <Setter Property="Background" Value="#3a3a3a"/>
        </Style>
        <Style Selector="Border.pickerPopup TimePicker">
            <Setter Property="Foreground" Value="#dcddde"/>
            <Setter Property="Background" Value="#2b2b2b"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#9ca3af"/>
        </Style>
        <Style Selector="TextBlock.faint">
            <Setter Property="Foreground" Value="#737373"/>
        </Style>
        <Style Selector="TextBlock.danger">
            <Setter Property="Foreground" Value="#ff9b9b"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0" Classes="toolbar" Padding="10,7">
            <Grid ColumnDefinitions="260,*,Auto" ColumnSpacing="10">
                <TextBox Classes="ghost"
                         Text="{Binding BoardTitle}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Padding="2"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button Content="Board" Command="{Binding SetBoardViewCommand}"/>
                    <Button Content="List" Command="{Binding SetListViewCommand}"/>
                    <Button Content="Table" Command="{Binding SetTableViewCommand}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                    <Button Content="Archive" Command="{Binding ToggleArchiveCommand}"/>
                    <Button Content="Settings" Command="{Binding ToggleSettingsCommand}"/>
                    <Button Content="+ Add swimlane" Command="{Binding AddSwimlaneCommand}"/>
                    <Button Content="+ Add list" Command="{Binding AddLaneCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="searchbar" Padding="13,10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBox Text="{Binding SearchQuery}"
                         PlaceholderText="Search cards..."
                         HorizontalAlignment="Right"
                         Width="320"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding TotalCards, StringFormat='{}{0} cards'}"
                           Classes="muted"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid RowDefinitions="Auto,*"
                  IsVisible="{Binding IsBoardView}">
                <Border Grid.Row="0"
                        Classes="boardColumnHeaderHost">
                    <ScrollViewer x:Name="ColumnHeaderScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  ScrollChanged="ColumnHeaderScrollViewer_ScrollChanged">
                        <ItemsControl ItemsSource="{Binding ColumnLanes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LaneViewModel">
                                    <Border Classes="columnHeader"
                                            Width="272"
                                            Margin="0,0,12,0"
                                            PointerPressed="LaneHeader_PointerPressed"
                                            PointerMoved="LaneHeader_PointerMoved"
                                            DoubleTapped="LaneHeader_DoubleTapped">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                                            <TextBlock Text="⋮⋮" Classes="faint" VerticalAlignment="Center"/>
                                            <Grid Grid.Column="1">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding IsDisplayMode}"/>
                                                <TextBox Text="{Binding Title}"
                                                         FontWeight="SemiBold"
                                                         KeyDown="LaneEdit_KeyDown"
                                                         LostFocus="LaneEdit_LostFocus"
                                                         IsVisible="{Binding IsEditing}"/>
                                            </Grid>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding WipText}"
                                                       Classes="muted"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Classes="cardMenu" Content="⋮" Padding="4">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Move left" Command="{Binding MoveLeftCommand}"/>
                                                        <MenuItem Header="Move right" Command="{Binding MoveRightCommand}"/>
                                                        <MenuItem Header="Sort now" Command="{Binding SortCommand}"/>
                                                        <MenuItem Header="Delete list" Command="{Binding DeleteLaneCommand}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <ScrollViewer x:Name="BoardBodyScrollViewer"
                              Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,8,16,16"
                              ClipToBounds="True"
                              ScrollChanged="BoardBodyScrollViewer_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding Swimlanes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SwimlaneViewModel">
                                <StackPanel Classes="swimlaneRow">
                                    <Border Classes="swimlaneBar"
                                            DoubleTapped="SwimlaneLabel_DoubleTapped">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       Classes="swimlaneTitle"
                                                       IsVisible="{Binding IsDisplayMode}"/>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Title}"
                                                     Classes="swimlaneTitle"
                                                     KeyDown="SwimlaneEdit_KeyDown"
                                                     LostFocus="SwimlaneEdit_LostFocus"
                                                     IsVisible="{Binding IsEditing}"/>
                                            <Button Grid.Column="1"
                                                    Classes="cardMenu"
                                                    Content="⋮"
                                                    Padding="3,0,0,0"
                                                    Margin="8,0,0,0">
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Rename swimlane" Command="{Binding BeginEditCommand}"/>
                                                        <MenuItem Header="Move up" Command="{Binding MoveUpCommand}"/>
                                                        <MenuItem Header="Move down" Command="{Binding MoveDownCommand}"/>
                                                        <MenuItem Header="Delete swimlane" Command="{Binding DeleteSwimlaneCommand}"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Lanes}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LaneViewModel">
                                <StackPanel Width="272"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Top">
                                    <Border Classes="laneCell">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Border Grid.Row="0" Padding="10,8" BorderBrush="#3a3a3a" BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="{Binding WipText}"
                                                               Classes="muted"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Classes="cardMenu" Content="⋮" Padding="4">
                                                        <Button.Flyout>
                                                            <MenuFlyout>
                                                                <MenuItem Header="Add a card" Command="{Binding AddCardCommand}"/>
                                                                <MenuItem Header="Sort now" Command="{Binding SortCommand}"/>
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <ItemsControl Grid.Row="1"
                                                          ItemsSource="{Binding FilteredCards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CardViewModel">
                                                    <Border Classes="card"
                                                            DragDrop.AllowDrop="True"
                                                            Focusable="True"
                                                            PointerPressed="Card_PointerPressed"
                                                            PointerMoved="Card_PointerMoved"
                                                            DoubleTapped="Card_DoubleTapped"
                                                            DragDrop.DragOver="Card_DragOver"
                                                            DragDrop.Drop="Card_Drop"
                                                            KeyDown="Card_KeyDown">
                                                        <Grid>
                                                            <StackPanel Spacing="5" IsVisible="{Binding IsDisplayMode}">
                                                                <Grid ColumnDefinitions="*,Auto" Margin="8,8,6,0">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               TextWrapping="Wrap"
                                                                               FontSize="13"
                                                                               Margin="0,1,4,0"/>
                                                                    <Button Grid.Column="1"
                                                                            Classes="cardMenu"
                                                                            Content="⋮"
                                                                            Padding="3"
                                                                            Tag="{Binding}"
                                                                            PointerPressed="CardMenu_PointerPressed">
                                                                        <Button.Flyout>
                                                                            <MenuFlyout>
                                                                                <MenuItem Header="编辑卡片" Command="{Binding BeginEditCommand}"/>
                                                                                <MenuItem Header="Move up" Command="{Binding MoveUpCommand}"/>
                                                                                <MenuItem Header="Move down" Command="{Binding MoveDownCommand}"/>
                                                                                <MenuItem Header="归档卡片" Command="{Binding ArchiveCommand}"/>
                                                                                <MenuItem Header="删除卡片" Command="{Binding DeleteCommand}"/>
                                                                                <Separator/>
                                                                                <MenuItem Header="{Binding DateMenuHeader}"
                                                                                          Click="CardMenu_Date_Click"/>
                                                                                <MenuItem Header="移除日期"
                                                                                          Command="{Binding ClearDueDateCommand}"
                                                                                          IsVisible="{Binding ShowRemoveDateMenu}"/>
                                                                                <MenuItem Header="{Binding TimeMenuHeader}"
                                                                                          Click="CardMenu_Time_Click"
                                                                                          IsVisible="{Binding ShowTimeMenuSection}"/>
                                                                                <MenuItem Header="移除时间"
                                                                                          Command="{Binding ClearDueTimeCommand}"
                                                                                          IsVisible="{Binding ShowRemoveTimeMenu}"/>
                                                                            </MenuFlyout>
                                                                        </Button.Flyout>
                                                                    </Button>
                                                                </Grid>

                                                                <ItemsControl ItemsSource="{Binding PreviewImages}"
                                                                              IsVisible="{Binding HasPreviewImages}"
                                                                              Margin="34,4,10,0">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                            <Image Classes="cardPreview"
                                                                                   Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                                   DoubleTapped="CardImage_DoubleTapped"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <TextBlock Text="{Binding Description}"
                                                                           Classes="muted"
                                                                           TextWrapping="Wrap"
                                                                           Margin="34,0,10,0"
                                                                           FontSize="12"
                                                                           IsVisible="{Binding HasDescription}"/>

                                                                <WrapPanel Margin="34,0,8,7">
                                                                    <Button Classes="tagButton dateBadge"
                                                                            Content="{Binding DateDisplayText}"
                                                                            IsVisible="{Binding HasDueDate}"
                                                                            Click="CardDateBadge_Click"/>
                                                                    <Button Classes="tagButton timeBadge"
                                                                            Content="{Binding TimeDisplayText}"
                                                                            IsVisible="{Binding HasDueTime}"
                                                                            Click="CardTimeBadge_Click"/>
                                                                    <Border Classes="tag" IsVisible="{Binding ShowRelativeDueBadge}">
                                                                        <TextBlock Text="{Binding DueBadge}" FontSize="11"/>
                                                                    </Border>
                                                                </WrapPanel>
                                                            </StackPanel>

                                                            <StackPanel Spacing="6" Margin="8" IsVisible="{Binding IsEditing}">
                                                                <TextBox Text="{Binding Title}"
                                                                         FontWeight="SemiBold"
                                                                         KeyDown="CardEdit_KeyDown"/>
                                                                <ItemsControl ItemsSource="{Binding PreviewImages}"
                                                                              IsVisible="{Binding HasPreviewImages}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:CardImageViewModel">
                                                                            <Image Classes="cardPreview"
                                                                                   Source="{Binding AbsolutePath, Converter={StaticResource FilePathToBitmap}}"
                                                                                   DoubleTapped="CardImage_DoubleTapped"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="拖放图片到卡片，或 Ctrl+V 粘贴"
                                                                           Classes="faint"
                                                                           FontSize="11"/>
                                                                <TextBox Classes="cardDetails"
                                                                         Text="{Binding Description}"
                                                                         PlaceholderText="Card details..."/>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <Button Classes="accent" Content="Done" Command="{Binding EndEditCommand}"/>
                                                                    <Button Content="Archive" Command="{Binding ArchiveCommand}"/>
                                                                    <Button Content="Delete" Command="{Binding DeleteCommand}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </Grid>
                                    </Border>
                                    <Border Classes="laneCellFooter">
                                        <StackPanel Spacing="0">
                                            <Border Padding="0,0,0,8" IsVisible="{Binding IsAddingCard}">
                                                <StackPanel Spacing="6">
                                                    <TextBox Text="{Binding NewCardTitle}" PlaceholderText="卡片标题..."/>
                                                    <TextBox Classes="cardDetails"
                                                             Text="{Binding NewCardDetails}"
                                                             PlaceholderText="详情..."/>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Button Classes="accent" Content="添加" Command="{Binding CommitAddCardCommand}"/>
                                                        <Button Content="取消" Command="{Binding CancelAddCardCommand}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Button Classes="laneAddCard"
                                                    Content="+ 添加卡片"
                                                    Command="{Binding AddCardCommand}"
                                                    IsVisible="{Binding IsAddCardButtonVisible}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24"
                          IsVisible="{Binding IsListView}">
                <StackPanel Spacing="8">
                    <ItemsControl ItemsSource="{Binding Swimlanes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SwimlaneViewModel">
                                <StackPanel Spacing="6" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"/>
                                    <ItemsControl ItemsSource="{Binding Lanes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LaneViewModel">
                                <Border Classes="lane" Padding="0" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Border Classes="laneHeader">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding FilteredCards}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CardViewModel">
                                                    <Border BorderBrush="#3a3a3a" BorderThickness="0,1,0,0" Padding="8">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Description}" Classes="muted" TextWrapping="Wrap" IsVisible="{Binding HasDescription}"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding DueBadge}" Classes="muted"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24" IsVisible="{Binding IsTableView}">
                <Border Classes="drawer" Padding="0">
                    <StackPanel>
                        <Border Background="#262626" Padding="10">
                            <Grid ColumnDefinitions="2*,3*,*" ColumnSpacing="12">
                                <TextBlock Text="Title" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Description" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Due" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                        <ItemsControl ItemsSource="{Binding TableCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CardViewModel">
                                    <Border BorderBrush="#3a3a3a" BorderThickness="0,1,0,0" Padding="10">
                                        <Grid ColumnDefinitions="2*,3*,*" ColumnSpacing="12">
                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}" Classes="muted" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="2" Text="{Binding DateDisplayText}" Classes="muted"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Classes="drawer"
                    Width="360"
                    Padding="14"
                    Margin="0,12,12,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    IsVisible="{Binding ShowArchive}">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Text="Archive" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ArchiveCount, StringFormat='{}{0} archived cards'}" Classes="muted"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="×" Command="{Binding ToggleArchiveCommand}"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
                        <ItemsControl ItemsSource="{Binding ArchiveCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CardViewModel">
                                    <Border Classes="card" Padding="9">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" Classes="muted" TextWrapping="Wrap" IsVisible="{Binding HasDescription}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button Content="Restore" Command="{Binding RestoreCommand}"/>
                                                <Button Content="Delete" Command="{Binding DeleteCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Classes="drawer"
                    Width="360"
                    Padding="14"
                    Margin="0,12,12,12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    IsVisible="{Binding ShowSettings}">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Board settings" FontSize="18" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="×" Command="{Binding ToggleSettingsCommand}"/>
                    </Grid>
                    <CheckBox Content="Show relative dates" IsChecked="{Binding ShowRelativeDates}"/>
                    <CheckBox Content="Prepend new cards" IsChecked="{Binding PrependNewCards}"/>
                    <TextBlock Text="Maximum archive size" Classes="muted"/>
                    <TextBox Text="{Binding MaxArchiveSizeText}"/>
                    <TextBlock Text="Date format" Classes="muted"/>
                    <TextBox Text="{Binding DateFormat}"/>
                    <Button Content="Reset sample board" Command="{Binding NewBoardCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}" Classes="muted" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Popup x:Name="DatePickerPopup"
               IsLightDismissEnabled="True"
               Placement="BottomEdgeAlignedLeft"
               OverlayDismissEventPassThrough="False"
               Closed="DatePickerPopup_Closed">
            <ThemeVariantScope RequestedThemeVariant="Dark">
                <Border Classes="pickerPopup">
                    <Calendar x:Name="DatePickerCalendar"
                              SelectionMode="SingleDate"
                              SelectedDatesChanged="DatePickerCalendar_SelectedDatesChanged"/>
                </Border>
            </ThemeVariantScope>
        </Popup>

        <Popup x:Name="TimePickerPopup"
               IsLightDismissEnabled="True"
               Placement="BottomEdgeAlignedLeft"
               OverlayDismissEventPassThrough="False"
               Closed="TimePickerPopup_Closed">
            <ThemeVariantScope RequestedThemeVariant="Dark">
                <Border Classes="pickerPopup" MinWidth="240">
                    <StackPanel Spacing="10">
                        <TimePicker x:Name="BoardTimePicker"
                                    ClockIdentifier="24HourClock"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Button Grid.Column="1"
                                    Content="取消"
                                    Click="TimePickerCancel_Click"/>
                            <Button Grid.Column="2"
                                    Classes="accent"
                                    Content="确认"
                                    Click="TimePickerConfirm_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </ThemeVariantScope>
        </Popup>

        <Canvas Grid.RowSpan="3" IsHitTestVisible="False">
            <Border x:Name="DragPreview"
                    IsVisible="False"
                    Width="244"
                    Background="#2d2d2d"
                    BorderBrush="#7f8cff"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="10"
                    Opacity="0.92">
                <TextBlock x:Name="DragPreviewText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           FontWeight="SemiBold"/>
            </Border>
        </Canvas>

        <Border x:Name="ImageLightbox"
                Grid.RowSpan="3"
                Classes="imageLightbox"
                IsVisible="False"
                Focusable="True"
                KeyDown="ImageLightbox_KeyDown"
                PointerPressed="ImageLightbox_Background_PointerPressed">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16,12,16,8">
                    <TextBlock x:Name="ImageLightboxTitle"
                               Classes="muted"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1"
                            Content="×"
                            Padding="10,4"
                            Click="ImageLightbox_Close_Click"/>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              Margin="16,0,16,16"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              PointerPressed="ImageLightbox_Scroll_PointerPressed">
                    <Image x:Name="ImageLightboxImage"
                           Stretch="None"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           DoubleTapped="ImageLightbox_Image_DoubleTapped"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
